# Orthanc — Environment Configuration
# Copy this file to .env and update values as needed.

# ── Database ──────────────────────────────────────────────
# Default values work with the included docker-compose.yml
POSTGRES_USER=orthanc
POSTGRES_PASSWORD=orthanc_dev
POSTGRES_DB=orthanc

# Connection string used by the backend
DATABASE_URL=postgresql+asyncpg://orthanc:orthanc_dev@postgres:5432/orthanc

# ── Authentication ────────────────────────────────────────
# CHANGE THIS in production — used to sign JWT tokens
JWT_SECRET=change-me-to-a-random-string

# ── Optional: Telegram Bot ────────────────────────────────
# Required only for Telegram alert delivery
# Create a bot via @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# ── Ports (change if you have conflicts) ──────────────────
# FRONTEND_PORT=3001
# BACKEND_PORT=8000
# POSTGRES_PORT=5433
